#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpx.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpx.cjs" "$@"
fi
# cmd-shim-target=/Users/jacobchampion/sweet-media-platform/.pnpm-store/v11/links/@/pnpm/10.33.2/23bda7ffb945bd7449a04e2991f336b36447afbbf10ccd57275d7a23ef5ca278/node_modules/pnpm/bin/pnpx.cjs
