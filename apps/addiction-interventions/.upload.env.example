# Minimal: service role key alone works — project ref is read from the JWT.
# Optional: set URL / ref explicitly if you use a non-default Supabase host.
#
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
#
# Optional overrides:
# SUPABASE_PROJECT_REF=bxtwcdgjzzjxjvqdiuvn
# SUPABASE_URL=https://bxtwcdgjzzjxjvqdiuvn.supabase.co
# NEXT_PUBLIC_SUPABASE_URL=https://bxtwcdgjzzjxjvqdiuvn.supabase.co
SUPABASE_BUCKET=site-assets
LOCAL_IMAGE_DIR=./state-upload-staging
