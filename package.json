{
  "name": "sweet-media-platform",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver"]
  },
  "scripts": {
    "dev": "turbo dev --filter=!@sweetmedia/client-template",
    "build": "turbo build --filter=!@sweetmedia/client-template",
    "lint": "turbo lint --filter=!@sweetmedia/client-template",
    "typecheck": "turbo typecheck --filter=!@sweetmedia/client-template",
    "new-client": "node scripts/setup-new-client.mjs",
    "scaffold-client": "node scripts/scaffold-client-app.mjs",
    "publish-client": "node scripts/publish-client-to-vercel.mjs",
    "invite-member": "node scripts/invite-team-member.mjs",
    "migrate-clients": "node scripts/migrate-all-clients.mjs",
    "crawl-brand-data": "node scripts/crawl-brand-data.mjs",
    "migrate-wp-images": "node scripts/migrate-wp-site-images.mjs",
    "dev-setup": "node scripts/dev-setup.mjs"
  },
  "devDependencies": {
    "@types/turndown": "^5.0.6",
    "playwright": "^1.59.1",
    "turbo": "^2.9.7",
    "turndown": "^7.2.4"
  }
}
